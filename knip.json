{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/app/**/*.{ts,tsx}!"],
  "project": ["src/**/*.{ts,tsx}!"],
  "ignoreDependencies": [
    "postcss-load-config",
    "shadcn",
    "tailwindcss",
    "tw-animate-css"
  ],
  "ignore": ["src/components/ui/**"],
  "exclude": ["exports", "types"],
  "paths": {
    "@/*": ["./src/*"]
  }
}
