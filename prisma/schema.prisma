generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth tables ─────────────────────────────────────────────

model User {
  id            String    @id
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  locale        String    @default("en")
  theme         String    @default("system")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions         Session[]
  accounts         Account[]
  capturedReceipts CapturedReceipt[]
  categories       Category[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt
}

// ─── App-specific tables ────────────────────────────────────────────

model CapturedReceipt {
  id         String   @id @default(cuid())
  userId     String
  imageHash  String
  imageData  String   @db.Text
  mimeType   String
  fileSize   Int?
  capturedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // ── Extraction fields ──
  extractionStatus String    @default("pending") // pending | processing | completed | failed
  vendorName       String?
  totalAmount      Decimal?  @db.Decimal(10, 2)
  receiptDate      DateTime?
  taxAmount        Decimal?  @db.Decimal(10, 2)
  paymentType      String?                       // "cash" | "card" | "other"
  rawExtraction    Json?                         // Full AI response for debugging
  verifiedAt       DateTime?                     // When user confirmed the data

  // ── Category & VAT ──
  categoryId    String?                          // Receipt-level category
  vatBreakdown  Json?                            // { "19": 23.81, "9": 4.50, ... }

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category?         @relation("ReceiptCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  items    ReceiptItem[]

  @@unique([userId, imageHash])
  @@index([userId])
  @@index([capturedAt])
  @@index([categoryId])
}

// ─── Category ───────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String                          // Display name (English)
  nameRo    String?                         // Romanian display name
  slug      String   @unique                // URL-safe identifier
  type      String                          // "receipt" | "product"
  color     String   @default("#6B7280")    // Hex color for chip
  icon      String?                         // Lucide icon name
  isCustom  Boolean  @default(false)        // User-created?
  userId    String?                         // null = system category
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  receipts CapturedReceipt[] @relation("ReceiptCategory")
  items    ReceiptItem[]     @relation("ItemCategory")

  @@unique([slug, userId])
  @@index([type])
  @@index([userId])
}

// ─── Receipt Line Items ─────────────────────────────────────────────

model ReceiptItem {
  id         String   @id @default(cuid())
  receiptId  String
  name       String
  quantity   Decimal  @db.Decimal(10, 3)   // Supports KG quantities like 0.456
  unitPrice  Decimal  @db.Decimal(10, 2)
  totalPrice Decimal  @db.Decimal(10, 2)
  vatRate    Decimal? @db.Decimal(4, 2)    // 19.00, 9.00, 5.00, or null (exempt)
  vatAmount  Decimal? @db.Decimal(10, 2)
  categoryId String?                       // Product-level category
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  receipt  CapturedReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  category Category?       @relation("ItemCategory", fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([receiptId])
  @@index([categoryId])
}
